<?xml version="1.0" encoding="utf-8"?>
<!-- Chat-style terminal: RecyclerView for bubbles, input bar at bottom -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/text_primary"
        android:theme="@style/ToolbarTheme"
        app:popupTheme="@style/WhitePopupMenu">

        <!-- Custom content: title + spacer + continue switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="my-project" />

            <TextView
                android:id="@+id/toolbar_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_green"
                android:textSize="11sp"
                tools:text="● connected" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/continue_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="continue"
                android:textColor="#8b949e"
                android:textSize="11sp"
                android:layout_marginEnd="4dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_continue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#74c0fc"
                android:trackTint="#30363d" />
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Chat message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="4dp"
        android:clipToPadding="false" />

    <!-- Input bar -->
    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:padding="6dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/input_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:hint="@string/msg_input_hint"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:inputType="text|textNoSuggestions"
            android:maxLines="1"
            android:imeOptions="actionSend"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:importantForAutofill="no" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send"
            android:tint="@color/accent_blue" />
    </LinearLayout>
</LinearLayout>
