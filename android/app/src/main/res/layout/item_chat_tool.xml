<?xml version="1.0" encoding="utf-8"?>
<!-- Tool call indicator — compact left-aligned bubble with a name line and an
     optional result/output snippet line. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:paddingHorizontal="12dp"
    android:paddingVertical="2dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_claude"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:layout_marginStart="6dp">

        <TextView
            android:id="@+id/tool_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFD43B"
            android:textSize="12sp"
            android:textStyle="italic"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="⚙ Bash · npm test" />

        <TextView
            android:id="@+id/tool_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:maxLines="3"
            android:ellipsize="end"
            android:visibility="gone"
            tools:text="→ nothing to commit, working tree clean" />
    </LinearLayout>
</LinearLayout>
