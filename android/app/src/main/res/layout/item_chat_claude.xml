<?xml version="1.0" encoding="utf-8"?>
<!-- Claude output bubble — left-aligned, dark gray -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:paddingHorizontal="6dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/chat_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bubble_claude"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:textColor="#C8D6E5"
            android:textSize="13sp"
            android:textIsSelectable="true"
            tools:text="Claude's response with **bold**, `code`, and tables" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chat_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#666666"
                android:textSize="10sp"
                android:layout_marginStart="6dp"
                tools:text="14:32" />

            <TextView
                android:id="@+id/btn_toggle_render"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textSize="10sp"
                android:textColor="#8B949E"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bubble_claude"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                tools:text="原文" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
